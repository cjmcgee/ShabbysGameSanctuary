<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile for x86_64 Windows. Self-contained — the .NET 10 runtime
  is bundled, so end users don't need anything pre-installed.

  Usage:
    dotnet publish ChildhoodAdventure -p:PublishProfile=win-x64 -c Release

  Output: bin/Publish/win-x64/, plus dist/ChildhoodAdventure-win-x64.zip
  (created by the ArchivePublishedOutput target in the .csproj).

  Stella on Windows: when this profile runs on a non-Windows host, the
  BuildStellaWindowsCore MSBuild target cross-compiles stella_libretro.dll
  via mingw-w64. If x86_64-w64-mingw32-g++ isn't on PATH it emits a
  warning (telling the user to `sudo apt install mingw-w64`) and the
  Windows archive ships without Combat — the in-game menu greys it out
  via GameLibrary's existing UnavailableReason fallback.
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\bin\Publish\win-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <PublishTrimmed>false</PublishTrimmed>
    <!-- Skip the make-driven native Stella build when publishing for Windows
         from a Linux/macOS host. The build host's libretro.so isn't usable
         on Windows anyway; the post-publish archive target picks up a
         prebuilt stella_libretro.dll if one exists. -->
    <BuildStellaLibretro>false</BuildStellaLibretro>
  </PropertyGroup>
</Project>
