<?xml version="1.0" encoding="utf-8"?>
<!--
  Publish profile for x86_64 Linux. Self-contained — the .NET 10 runtime
  is bundled, so end users don't need anything pre-installed.

  Usage:
    dotnet publish MainGame -p:PublishProfile=linux-x64 -c Release

  Output: bin/Publish/linux-x64/, plus dist/ShabbysGameSanctuary-linux-x64.tar.gz
  (created by the ArchivePublishedOutput target in the .csproj).
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>$(MSBuildThisFileDirectory)..\..\bin\Publish\linux-x64\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>false</PublishSingleFile>
    <PublishReadyToRun>false</PublishReadyToRun>
    <!-- Trimming breaks MonoGame's reflection-based content pipeline. -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>
</Project>
