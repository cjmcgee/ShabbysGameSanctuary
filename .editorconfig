root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.cs]
indent_style = tab
indent_size = 4
tab_width = 4

# CA1031: Do not catch general exception types
dotnet_diagnostic.CA1031.severity = suggestion

# CA5394: System.Random is fine for non-security game randomness
dotnet_diagnostic.CA5394.severity = none

# CA1308: ToLowerInvariant is conventional for animation keys / asset IDs
dotnet_diagnostic.CA1308.severity = none

# CA1724: Engine type names (Npc, ObjectPool, StateMachine) match their
# namespaces by intent — single-purpose, single-type namespaces.
dotnet_diagnostic.CA1724.severity = none

[*.{json,md,yml,yaml}]
indent_style = space
indent_size = 2
