# Git LFS tracked file types.
# New commits matching these patterns are stored as LFS pointers.
# Existing tracked blobs are unaffected; use `git lfs migrate import` to convert history.
#
# NOTE: Raster images (*.png, *.gif, *.jpg, *.jpeg, *.bmp, *.tga, *.webp) and image source
# files (*.ase, *.aseprite, *.psd) are intentionally NOT tracked by LFS. They were migrated
# out of LFS and back into normal git on 2026-06-07 (the ~23k LFS pointers were exhausting
# GitHub's API rate limit). Do not re-add these patterns here.

# Native libraries
*.so       filter=lfs diff=lfs merge=lfs -text
*.dll      filter=lfs diff=lfs merge=lfs -text
*.dylib    filter=lfs diff=lfs merge=lfs -text
*.a        filter=lfs diff=lfs merge=lfs -text
*.lib      filter=lfs diff=lfs merge=lfs -text

# Audio
*.wav      filter=lfs diff=lfs merge=lfs -text
*.mp3      filter=lfs diff=lfs merge=lfs -text
*.ogg      filter=lfs diff=lfs merge=lfs -text

# Video
*.mp4      filter=lfs diff=lfs merge=lfs -text
*.mov      filter=lfs diff=lfs merge=lfs -text

# Archives
*.zip      filter=lfs diff=lfs merge=lfs -text
*.7z       filter=lfs diff=lfs merge=lfs -text
*.tar.gz   filter=lfs diff=lfs merge=lfs -text

# Fonts
*.ttf      filter=lfs diff=lfs merge=lfs -text
*.otf      filter=lfs diff=lfs merge=lfs -text

# Executables
*.exe      filter=lfs diff=lfs merge=lfs -text
